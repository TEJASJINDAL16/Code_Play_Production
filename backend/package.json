{
  "name": "codeplay-backend",
  "version": "1.0.0",
  "description": "CodePlay Backend API — Express.js server with real-time collaboration, AI assistant, and code judge",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "healthcheck": "node -e \"fetch('http://localhost:' + (process.env.PORT || 5000) + '/api/health').then(r => { console.log(r.ok ? 'OK' : 'FAIL'); process.exit(r.ok ? 0 : 1); }).catch(e => { console.error(e.message); process.exit(1); })\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.985.0",
    "@google/generative-ai": "^0.24.1",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.0.0",
    "cheerio": "^1.1.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.1",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.15.0",
    "mongoose": "^9.0.1",
    "nodemailer": "^7.0.11",
    "socket.io": "^4.8.1",
    "ws": "^8.18.3",
    "y-websocket": "^1.5.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.0.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.0",
    "puppeteer": "^24.35.0",
    "supertest": "^7.2.2"
  }
}
