# ===========================================
# CODEPLAY BACKEND - ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in your values

# Database
MONGO_URI=mongodb://localhost:27017/codeplay
# OR for MongoDB Atlas:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/codeplay

# JWT Secret (generate a secure random string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# ===========================================
# OAUTH PROVIDERS (Optional but recommended)
# ===========================================

# Google OAuth
# Get these from: https://console.cloud.google.com/apis/credentials
# 1. Create a new OAuth 2.0 Client ID
# 2. Add authorized redirect URI: {BACKEND_URL}/api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth  
# Get these from: https://github.com/settings/developers
# 1. Create a new OAuth App
# 2. Set Homepage URL to your frontend URL
# 3. Set Authorization callback URL: {BACKEND_URL}/api/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ===========================================
# EMAIL (For password reset)
# ===========================================

# Gmail (enable "Less secure apps" or use App Password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ===========================================
# AI ASSISTANT
# ===========================================

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ===========================================
# OPTIONAL SERVICES
# ===========================================

# Redis (for caching - optional)
# REDIS_URL=redis://localhost:6379

# Node Environment
NODE_ENV=development
